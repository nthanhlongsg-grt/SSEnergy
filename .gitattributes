# Auto detect text files and perform LF normalization
* text=auto

# Force LF line endings for these files
*.bat text eol=crlf
*.ps1 text eol=crlf
*.sh text eol=lf

# Force binary for these files
*.db binary
*.db-journal binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
