# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Timezone (bắt buộc trên Linux hosting) ──────────────────────────────────
TZ=Asia/Ho_Chi_Minh

# ─── Database ─────────────────────────────────────────────────────────────────
# Đường dẫn tuyệt đối đến file SQLite trên server
# Ví dụ Mắt Bão: /home/gro99259/api_growattvietnam.com/database/growatt.db
DATABASE_PATH=/home/<username>/<appname>/database/growatt.db

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Tạo chuỗi ngẫu nhiên dài ít nhất 32 ký tự
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Domain(s) của frontend, phân cách nhau bằng dấu phẩy
# Ví dụ: https://growatt.yourdomain.com
# Hoặc nhiều domain: https://domain1.com,https://domain2.com
CORS_ORIGIN=https://your-frontend-domain.com
